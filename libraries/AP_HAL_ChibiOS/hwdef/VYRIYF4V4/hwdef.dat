include ../speedybeef4v4/hwdef.dat

# Принудительно включаем драйвер барометра
define AP_BARO_DPS310_ENABLED 1

# Переназначаем барометр на I2C2 (PB10/PB11)
undef PB10
undef PB11
PB10 I2C2_SCL I2C2
PB11 I2C2_SDA I2C2

undef I2C_ORDER
I2C_ORDER I2C2 I2C1

undef BARO
BARO DPS310 I2C:0:0x76

# ГЛАВНАЯ СТРОКА: говорим использовать загрузчик от SpeedyBee
env set ROMFS_FILES [('bootloader.bin', 'Tools/bootloaders/speedybeef4v4_bl.bin')]

define FLASH_BOOTLOADER_LOAD_KB 48







































