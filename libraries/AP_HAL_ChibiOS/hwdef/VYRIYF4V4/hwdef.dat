include ../speedybeef4v4/hwdef.dat

# 1. Отключаем барометр SpeedyBee (SPL06)
undef AP_BARO_SPL06_ENABLED
undef BARO

# 2. Включаем наш барометр DPS310
define AP_BARO_DPS310_ENABLED 1
define AP_BARO_BACKEND_DEFAULT_ENABLED 1
BARO DPS310 I2C:0:0x76

# 3. Настраиваем I2C2 (PB10/PB11)
undef PB10
undef PB11
PB10 I2C2_SCL I2C2
PB11 I2C2_SDA I2C2

undef I2C_ORDER
I2C_ORDER I2C2 I2C1

# 4. Параметры памяти
define FLASH_BOOTLOADER_LOAD_KB 48








































